{
  "name": "laravel-chronicle/anchor-s3",
  "description": "S3 Object Lock (WORM) anchoring adapter for the Chronicle audit ledger.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "laravel",
    "chronicle",
    "audit",
    "anchoring",
    "s3",
    "object-lock",
    "worm",
    "aws"
  ],
  "authors": [
    {
      "name": "Vasileios Ntoufoudis",
      "email": "info@ntoufoudis.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "laravel-chronicle/core": "@dev",
    "aws/aws-sdk-php": "^3.0"
  },
  "require-dev": {
    "laravel/pint": "^1.14",
    "larastan/larastan": "^3.0",
    "orchestra/testbench": "^10.0||^11.0",
    "pestphp/pest": "^3.0||^4.0",
    "pestphp/pest-plugin-laravel": "^3.0||^4.0"
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "autoload": {
    "psr-4": {
      "Chronicle\\AnchorS3\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Chronicle\\AnchorS3\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Chronicle\\AnchorS3\\AnchorS3ServiceProvider"
      ]
    }
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "scripts": {
    "analyse": "vendor/bin/phpstan analyse --memory-limit=2G",
    "test": "vendor/bin/pest"
  },
  "repositories": [
    {
      "type": "path",
      "url": "../core",
      "options": {
        "symlink": true
      }
    }
  ]
}
